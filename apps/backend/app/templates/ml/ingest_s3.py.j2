# ── AWS S3 Ingest ────────────────────────────────────────────────────────────
import pandas as pd
import boto3

s3_client_{{ node_id }} = boto3.client("s3", region_name="{{ config.aws_region | default('us-east-1') }}")
s3_obj_{{ node_id }} = s3_client_{{ node_id }}.get_object(
    Bucket="{{ config.bucket }}", Key="{{ config.key }}"
)
{% if config.file_format == 'parquet' %}
df_{{ node_id }} = pd.read_parquet(s3_obj_{{ node_id }}["Body"])
{% elif config.file_format == 'json' %}
df_{{ node_id }} = pd.read_json(s3_obj_{{ node_id }}["Body"])
{% else %}
df_{{ node_id }} = pd.read_csv(s3_obj_{{ node_id }}["Body"])
{% endif %}
print(f"[S3 Ingest] Loaded {len(df_{{ node_id }})} rows from s3://{{ config.bucket }}/{{ config.key }}")
