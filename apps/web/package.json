{
  "name": "@ai-ide/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "clean": "rm -rf dist",
    "test:e2e": "playwright test",
    "record-demo": "playwright test e2e/record-demo.ts --config playwright.record.config.ts",
    "capture-shots": "playwright test e2e/capture-shots.ts --config playwright.record.config.ts"
  },
  "dependencies": {
    "@ai-ide/canvas-engine": "workspace:*",
    "@ai-ide/node-registry": "workspace:*",
    "@ai-ide/types": "workspace:*",
    "@ai-ide/ui": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.4.1",
    "json-schema": "^0.4.0",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/json-schema": "^7.0.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
