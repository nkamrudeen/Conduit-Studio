# ── Regression Evaluation ─────────────────────────────────────────────────────
import numpy as np
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score
{% if config.plot_residuals %}
import matplotlib
matplotlib.use('Agg')  # non-interactive backend — prevents GUI hang in subprocess
import matplotlib.pyplot as plt
{% endif %}

{% set model_v = inputs['model'] if 'model' in inputs else input_var %}
{% set df_test_v = inputs['df_test'] if 'df_test' in inputs else input_var %}

_X_test_{{ node_id }} = {{ df_test_v }}.drop(columns=["{{ config.target_column }}"])
_y_test_{{ node_id }} = {{ df_test_v }}["{{ config.target_column }}"]
_y_pred_{{ node_id }} = {{ model_v }}.predict(_X_test_{{ node_id }})
_mae_{{ node_id }} = mean_absolute_error(_y_test_{{ node_id }}, _y_pred_{{ node_id }})
_rmse_{{ node_id }} = np.sqrt(mean_squared_error(_y_test_{{ node_id }}, _y_pred_{{ node_id }}))
_r2_{{ node_id }} = r2_score(_y_test_{{ node_id }}, _y_pred_{{ node_id }})

print(f"[Regression] MAE={_mae_{{ node_id }}:.4f}  RMSE={_rmse_{{ node_id }}:.4f}  R²={_r2_{{ node_id }}:.4f}")

{% if config.plot_residuals %}
_residuals_{{ node_id }} = _y_test_{{ node_id }}.values - _y_pred_{{ node_id }}
fig_{{ node_id }}, axes_{{ node_id }} = plt.subplots(1, 2, figsize=(12, 5))
axes_{{ node_id }}[0].scatter(_y_pred_{{ node_id }}, _residuals_{{ node_id }}, alpha=0.5)
axes_{{ node_id }}[0].axhline(0, color="red", linestyle="--")
axes_{{ node_id }}[0].set_xlabel("Predicted"); axes_{{ node_id }}[0].set_ylabel("Residuals")
axes_{{ node_id }}[0].set_title("Residuals vs Predicted")
axes_{{ node_id }}[1].scatter(_y_test_{{ node_id }}, _y_pred_{{ node_id }}, alpha=0.5)
axes_{{ node_id }}[1].plot([_y_test_{{ node_id }}.min(), _y_test_{{ node_id }}.max()],
                            [_y_test_{{ node_id }}.min(), _y_test_{{ node_id }}.max()], "r--")
axes_{{ node_id }}[1].set_xlabel("Actual"); axes_{{ node_id }}[1].set_ylabel("Predicted")
axes_{{ node_id }}[1].set_title("Actual vs Predicted")
plt.tight_layout()
plt.savefig("regression_evaluation.png", dpi=150)
print("[Regression] Residual plots saved to regression_evaluation.png")
{% endif %}

metrics_{{ node_id }} = {"mae": _mae_{{ node_id }}, "rmse": _rmse_{{ node_id }}, "r2": _r2_{{ node_id }}}
