# ── Fine-tuning: LoRA Configuration ──────────────────────────────────────────
import os as _os
from transformers import AutoModelForCausalLM, AutoTokenizer
from peft import LoraConfig, TaskType, get_peft_model

{% set source = config.model_source | default('huggingface') %}
{% set base = config.base_model | default('microsoft/Phi-3.5-mini-instruct') %}

base_model_{{ node_id }} = {{ base | tojson }}

{% if source == 'huggingface' %}
# Inject HF token for gated models (Llama, Gemma, etc.)
_hf_token_{{ node_id }} = _os.environ.get("{{ config.hf_token_env | default('HF_TOKEN') }}", "")
_load_kwargs_{{ node_id }} = {"token": _hf_token_{{ node_id }}} if _hf_token_{{ node_id }} else {}
print(f"[LoRAConfig] Loading from HuggingFace: {base_model_{{ node_id }}}{'  (authenticated)' if _hf_token_{{ node_id }} else '  (no token — gated models will fail)'}")
{% elif source == 'local_path' %}
_load_kwargs_{{ node_id }} = {"local_files_only": True}
print(f"[LoRAConfig] Loading from local path: {base_model_{{ node_id }}}")
{% elif source == 'ollama_export' %}
# Ollama export path: run  ollama_export node first to get HF-format weights
_load_kwargs_{{ node_id }} = {"local_files_only": True}
print(f"[LoRAConfig] Loading Ollama-exported model from: {base_model_{{ node_id }}}")
{% endif %}

tokenizer_{{ node_id }} = AutoTokenizer.from_pretrained(base_model_{{ node_id }}, use_fast=True, **_load_kwargs_{{ node_id }})
if tokenizer_{{ node_id }}.pad_token is None:
    tokenizer_{{ node_id }}.pad_token = tokenizer_{{ node_id }}.eos_token

model_base_{{ node_id }} = AutoModelForCausalLM.from_pretrained(
    base_model_{{ node_id }},
    device_map="auto",
    torch_dtype="auto",
    **_load_kwargs_{{ node_id }},
)

config_{{ node_id }} = LoraConfig(
    r={{ config.r | default(16) }},
    lora_alpha={{ config.lora_alpha | default(32) }},
    lora_dropout={{ config.lora_dropout | default(0.05) }},
    target_modules={{ config.target_modules | default(['q_proj', 'v_proj', 'k_proj', 'o_proj']) | tojson }},
    bias="{{ config.bias | default('none') }}",
    task_type=TaskType.{{ config.task_type | default('CAUSAL_LM') }},
)
print(f"[LoRAConfig] Base: {base_model_{{ node_id }}} | rank={config_{{ node_id }}.r}, alpha={config_{{ node_id }}.lora_alpha}")
