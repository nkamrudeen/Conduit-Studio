# ── Cross-Validation ──────────────────────────────────────────────────────────
import numpy as np
from sklearn.model_selection import cross_val_score

{% set model_v = inputs['model'] if 'model' in inputs else input_var %}
{% set df_v = inputs['df_in'] if 'df_in' in inputs else input_var %}

_X_all_{{ node_id }} = {{ df_v }}.drop(columns=["{{ config.target_column }}"])
_y_all_{{ node_id }} = {{ df_v }}["{{ config.target_column }}"]

_cv_scores_{{ node_id }} = cross_val_score(
    {{ model_v }},
    _X_all_{{ node_id }}, _y_all_{{ node_id }},
    cv={{ config.cv | default(5) }},
    scoring="{{ config.scoring | default('accuracy') }}",
    n_jobs=-1,
)
print(f"[Cross-Val] {{{ config.cv | default(5) }}}-fold {config.scoring | default('accuracy')}: "
      f"{_cv_scores_{{ node_id }}.mean():.4f} ± {_cv_scores_{{ node_id }}.std():.4f}")
metrics_{{ node_id }} = {
    "cv_mean": float(_cv_scores_{{ node_id }}.mean()),
    "cv_std": float(_cv_scores_{{ node_id }}.std()),
    "cv_scores": _cv_scores_{{ node_id }}.tolist(),
}
