# ── Logistic Regression Training ─────────────────────────────────────────────
from sklearn.linear_model import LogisticRegression
import pandas as pd

_df_{{ node_id }} = {{ input_var }}
_X_{{ node_id }} = _df_{{ node_id }}.drop(columns=["{{ config.target_column }}"])
_y_{{ node_id }} = _df_{{ node_id }}["{{ config.target_column }}"]

model_{{ node_id }} = LogisticRegression(
    C={{ config.C | default(1.0) }},
    max_iter={{ config.max_iter | default(1000) }},
    solver="{{ config.solver | default('lbfgs') }}",
    n_jobs=-1,
)
model_{{ node_id }}.fit(_X_{{ node_id }}, _y_{{ node_id }})
print(f"[Logistic Regression] Converged in {model_{{ node_id }}.n_iter_[0]} iterations")
