# ── Pinecone Vector Store ─────────────────────────────────────────────────────
import os
from langchain_pinecone import PineconeVectorStore
from pinecone import Pinecone

{% set chunks_v = inputs['chunks'] if 'chunks' in inputs else input_var %}
{% set embed_v = inputs['embeddings'] if 'embeddings' in inputs else None %}

_pc_{{ node_id }} = Pinecone(api_key=os.environ["{{ config.api_key_env | default('PINECONE_API_KEY') }}"])
vectorstore_{{ node_id }} = PineconeVectorStore.from_documents(
    documents={{ chunks_v }},
    {% if embed_v %}
    embedding={{ embed_v }},
    {% endif %}
    index_name="{{ config.index_name }}",
)
print(f"[Pinecone] Stored {len({{ chunks_v }})} chunks in index '{{ config.index_name }}'")
