# ── Train / Test Split ───────────────────────────────────────────────────────
import pandas as pd
from sklearn.model_selection import train_test_split as _tts

_X_{{ node_id }} = {{ input_var }}.drop(columns=["{{ config.target_column }}"])
_y_{{ node_id }} = {{ input_var }}["{{ config.target_column }}"]

_X_tr_{{ node_id }}, _X_te_{{ node_id }}, _y_tr_{{ node_id }}, _y_te_{{ node_id }} = _tts(
    _X_{{ node_id }}, _y_{{ node_id }},
    test_size={{ config.test_size | default(0.2) }},
    random_state={{ config.random_state | default(42) }},
    {% if config.stratify %}stratify=_y_{{ node_id }},{% endif %}
)

# Reconstruct labelled DataFrames for downstream nodes
df_train_{{ node_id }} = _X_tr_{{ node_id }}.copy()
df_train_{{ node_id }}["{{ config.target_column }}"] = _y_tr_{{ node_id }}.values
df_test_{{ node_id }} = _X_te_{{ node_id }}.copy()
df_test_{{ node_id }}["{{ config.target_column }}"] = _y_te_{{ node_id }}.values

print(f"[Split] Train: {len(df_train_{{ node_id }})} rows | Test: {len(df_test_{{ node_id }})} rows")
